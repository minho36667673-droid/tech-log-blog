---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import config from '../../blog.config.js';

// 발행된 포스트만, 날짜 역순으로
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recentPosts = allPosts.slice(0, 12);
---

<BaseLayout>
  <!-- 히어로 -->
  <section class="hero">
    <div class="container">
      <h1>{config.name}</h1>
      <p>{config.description}</p>
    </div>
  </section>

  <!-- 포스트 목록 -->
  <section class="container">
    {recentPosts.length === 0 ? (
      <div style="text-align:center; padding: 4rem 0; color: var(--color-text-muted);">
        <p>준비 중입니다. 곧 유용한 정보를 제공하겠습니다!</p>
      </div>
    ) : (
      <div class="posts-grid">
        {recentPosts.map(post => (
          <article class="post-card">
            <div class="post-card-body">
              <div class="category">{post.data.category}</div>
              <h2><a href={`/blog/${post.slug}/`}>{post.data.title}</a></h2>
              <p class="desc">{post.data.description}</p>
              <div class="meta">
                {post.data.pubDate.toLocaleDateString('ko-KR')} · {post.data.author}
              </div>
            </div>
          </article>
        ))}
      </div>
    )}

    <!-- 더 많은 포스트가 있을 경우 -->
    {allPosts.length > 12 && (
      <div style="text-align:center; padding: 1rem 0 3rem;">
        <a href="/blog/" style="display:inline-block; padding: 0.6rem 1.5rem; background: var(--color-primary); color: #fff; border-radius: 6px; font-weight: 600;">
          전체 글 보기 ({allPosts.length}개)
        </a>
      </div>
    )}
  </section>
</BaseLayout>
